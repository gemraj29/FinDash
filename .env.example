# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=findash
POSTGRES_PASSWORD=findash_secret
POSTGRES_DB=findash
DATABASE_URL="postgresql://findash:findash_secret@localhost:5432/findash?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PRICE_UPDATES=findash.price-updates
KAFKA_GROUP_ID=findash-api

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bit-random-string
JWT_EXPIRES_IN=7d

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development

# ─── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
